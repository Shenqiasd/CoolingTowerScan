# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Mapbox (卫星地图截图)
# 在 https://account.mapbox.com/ 获取
VITE_MAPBOX_TOKEN=your-mapbox-token

# AMap Web Service API (地址搜索/地理编码)
# 在高德开放平台创建 Web 服务 key
VITE_AMAP_API_KEY=

# Detection API (Railway 检测服务)
# 生产环境请填写你的 Railway 检测服务域名，例如 https://detection-production-xxxx.up.railway.app
VITE_DETECTION_API_URL=
